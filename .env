# N96_freq Configuration
# Copy this file to .env and edit the values below.

# Server port (default: 3001)
PORT=3001

# Path to your music folder (required)
# Windows example: C:/Users/YourName/Music
# macOS example: /Users/YourName/Music
# Linux example: /home/yourname/Music
MUSIC_DIR=C:\Users\AyoNym\Desktop\Music

# Spotify API credentials (optional — needed for Spotify playlist integration)
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=6cfb3a716c4641debb754e1f444e5939
SPOTIFY_CLIENT_SECRET=db9f27c94e4b437d885e448728fb207b
