# Normalize line endings — stop LF/CRLF warnings on Windows
# All text files use LF in the repo; Git converts to CRLF on checkout for Windows users
* text=auto eol=lf

# Explicitly declare files that should always use LF (scripts, configs)
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.svg text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.yml text eol=lf

# Binary files — don't touch
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.mp3 binary
*.wav binary
*.ogg binary
*.flac binary
*.mp4 binary
*.webm binary
*.zip binary
